# 数据库连接凭证：mysql://用户名:密码@主机IP:端口/数据库名
DATABASE_URL=mysql://root:password@127.0.0.1:3306/test_db
# 数据库连接池的最大连接数
DATABASE_POOL_SIZE=5

# Web 服务的监听端口
SERVER_PORT=8080

# CORS 允许的域名白名单列表（多个域名用逗号分隔，严禁包含多余空格）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5173,https://yourfrontapp.com
# 限流配置
# 每个客户端 IP 的最大突发请求桶容量（例如：最多允许连续连击 10 次）
RATE_LIMIT_BURST=10
# 每秒钟每个 IP 恢复的可用请求数（例如：每秒只给客户端恢复 2 个请求配额）
RATE_LIMIT_PER_SECOND=2

# JWT 安全配置
JWT_SECRET=your_super_secret_key_change_me_in_production
# 访问令牌生命周期（短，例如 15 分钟 = 900 秒）
JWT_ACCESS_EXPIRATION_SECS=900
# 刷新令牌生命周期（长，例如 7 天 = 604800 秒）
JWT_REFRESH_EXPIRATION_SECS=604800

# 零代码认证映射配置：指定用户认证表、账号字段、密码字段
AUTH_USERNAME_COL=username
AUTH_PASSWORD_COL=password
